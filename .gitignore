celerybeat-schedule
celerybeat.pid

# ─── Logs ───────────────────────────────────────────────────────
*.log

# ─── TLS certs (if generated locally) ──────────────────────────
certs/

# ─── Foundry (if initialized in uploads) ────────────────────────
# Foundry artifacts inside uploaded projects are ephemeral

