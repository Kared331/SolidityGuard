DATABASE_URL=postgresql+asyncpg://solidiguard:${POSTGRES_PASSWORD}@localhost:5432/solidiguard
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0
APP_PORT=8000
API_KEY=your-secret-api-key-here

# Upload limits (1.24)
MAX_UPLOAD_SIZE_MB=50

# Cleanup (5.20) – days before uploads/reports are deleted
CLEANUP_DAYS=30

# Database (1.8) – used by docker-compose
POSTGRES_USER=solidiguard
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=solidiguard

# Redis (1.8) – used by docker-compose
REDIS_PASSWORD=change-me-in-production

# GitHub API (4.16) – optional, for higher SWC sync rate limits
GITHUB_TOKEN=

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
CHROMA_PERSIST_DIR=./chroma_data

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=your-llm-api-key
LLM_MODEL_NAME=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1
RAG_TOP_K=5

# Logging (4.21)
LOG_LEVEL=INFO

# Frontend (build-time) – passed to frontend Dockerfile
VITE_API_BASE_URL=/api
